@model PetShop.ViewModels.ProductViewModel
@{
    ViewBag.Title = "Sửa Sản phẩm";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="stats-card">
            <h4 class="mb-4"><i class="fas fa-edit"></i> Sửa Sản phẩm: @Model.TenThuCung</h4>

            @using (Html.BeginForm("EditProduct", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.MaThuCung)
                @Html.HiddenFor(m => m.Hinh)
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="row">
                    <div class="col-md-6 mb-3">
                        @Html.LabelFor(m => m.TenThuCung, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.TenThuCung, new { @class = "form-control", placeholder = "Nhập tên thú cưng" })
                        @Html.ValidationMessageFor(m => m.TenThuCung, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-6 mb-3">
                        @Html.LabelFor(m => m.MaLoai, "Loại", new { @class = "form-label" })
                        @Html.DropDownListFor(m => m.MaLoai, (SelectList)ViewBag.Categories, "-- Chọn loại --", new { @class = "form-select" })
                        @Html.ValidationMessageFor(m => m.MaLoai, "", new { @class = "text-danger" })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        @Html.LabelFor(m => m.GioiTinh, new { @class = "form-label" })
                        @Html.DropDownListFor(m => m.GioiTinh, new SelectList(new[] { "Đực", "Cái" }), "-- Chọn --", new { @class = "form-select" })
                        @Html.ValidationMessageFor(m => m.GioiTinh, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-4 mb-3">
                        @Html.LabelFor(m => m.NgaySinh, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.NgaySinh, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                    </div>

                    <div class="col-md-4 mb-3">
                        @Html.LabelFor(m => m.MauSac, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.MauSac, new { @class = "form-control", placeholder = "Ví dụ: Trắng, Vàng" })
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        @Html.LabelFor(m => m.Gia, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.Gia, new { @class = "form-control", type = "number", step = "1000", placeholder = "Nhập giá" })
                        @Html.ValidationMessageFor(m => m.Gia, "", new { @class = "text-danger" })
                    </div>
                    <div class="col-md-6 mb-3">
                        @Html.LabelFor(m => m.GiaKhuyenMai, new { @class = "form-label" })
                        @Html.TextBoxFor(m => m.GiaKhuyenMai, new { @class = "form-control", type = "number", step = "1000", placeholder = "Nhập giá" })
                        @Html.ValidationMessageFor(m => m.Gia, "", new { @class = "text-danger" })
                    </div>

                    <div class="col-md-6 mb-3">
                        @Html.LabelFor(m => m.TrangThai, new { @class = "form-label" })
                        @Html.DropDownListFor(m => m.TrangThai, new SelectList(new[] { "Còn hàng", "Đã bán", "Đang đặt trước" }), new { @class = "form-select" })
                    </div>
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.MoTa, new { @class = "form-label" })
                    @Html.TextAreaFor(m => m.MoTa, new { @class = "form-control", rows = 4, placeholder = "Mô tả chi tiết về sản phẩm" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.ImageUpload, "Thay đổi hình ảnh", new { @class = "form-label" })
                    @if (!string.IsNullOrEmpty(Model.Hinh))
                    {
                        <div class="mb-2">
                            <img src="~/Content/Images/thucung/@Model.Hinh" alt="Current" class="img-thumbnail" style="max-width: 200px;">
                            <p class="text-muted">Hình hiện tại</p>
                        </div>
                    }
                    <input type="file" name="ImageUpload" class="form-control" accept="image/*" />
                    <small class="text-muted">Để trống nếu không muốn thay đổi hình</small>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-admin-primary">
                        <i class="fas fa-save"></i> Cập nhật
                    </button>
                    <a href="@Url.Action("Products")" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Hủy
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
