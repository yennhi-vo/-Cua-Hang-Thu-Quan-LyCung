@model PetShop.DichVu
@{
    ViewBag.Title = "Thêm Dịch Vụ";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card p-4 shadow-sm" style="max-width: 800px; margin: auto;">
    <h4><i class="fas fa-concierge-bell text-success"></i> Thêm Dịch Vụ Mới</h4>
    <hr />

    @using (Html.BeginForm("ThemDichVu", "Admin", FormMethod.Post, new { enctype = "multipart/form-data" }))
    {
        <div class="mb-3">
            <label class="form-label fw-bold">Tên dịch vụ</label>
            @Html.TextBoxFor(m => m.TenDichVu, new { @class = "form-control", placeholder = "VD: Tắm tỉa lông, Khám sức khỏe...", required = "required" })
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Giá dịch vụ (VNĐ)</label>
            @Html.TextBoxFor(m => m.Gia, new { @class = "form-control", type = "number", required = "required" })
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Giá khuyến mãi (nếu có)</label>
            @Html.TextBoxFor(m => m.GiaKhuyenMai, new { @class = "form-control", type = "number" })
        </div>
        <div class="mb-3">
            <label class="form-label fw-bold">Ảnh minh họa</label>
            <input type="file" name="uploadImage" class="form-control" accept="image/*" />
        </div>

        <div class="mb-3">
            <label class="form-label fw-bold">Mô tả dịch vụ</label>
            @Html.TextAreaFor(m => m.MoTa, new { @class = "form-control", rows = "4" })
        </div>

        <div class="text-end">
            <a href="@Url.Action("DanhSachDichVu")" class="btn btn-secondary">Hủy</a>
            <button type="submit" class="btn btn-success">Thêm Dịch Vụ</button>
        </div>
    }
</div>