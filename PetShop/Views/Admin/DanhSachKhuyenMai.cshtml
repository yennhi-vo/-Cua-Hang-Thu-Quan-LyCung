@model IEnumerable<PetShop.KhuyenMai>
@{
    ViewBag.Title = "Quản lý Khuyến Mãi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@* Phần tiêu đề và nút chức năng *@
<div class="row mb-4">
    <div class="col-md-12 text-start">
        @* Nút Tạo mã mới đã được chuyển về bên trái và giữ màu xanh lá đồng bộ *@
        <a href="@Url.Action("ThemKhuyenMai")" class="btn btn-admin-primary">
            <i class="fas fa-plus-circle"></i> Tạo mã mới
        </a>
    </div>
</div>

<div class="admin-table shadow-sm">
    <table class="table align-middle mb-0">
        @* Header bảng với tông màu xanh lá nhạt của hệ thống *@
        <thead style="background-color: #8BC97A; color: #000;">
            <tr>
                <th class="ps-3">Mã Code</th>
                <th>% Giảm</th>
                <th>Ngày Bắt Đầu</th>
                <th>Ngày Kết Thúc</th>
                <th>Trạng Thái</th>
                <th class="text-center">Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3 fw-bold text-dark">@item.CodeKM</td> @* Hiển thị mã giảm giá *@
                        <td class="text-danger fw-bold">@item.PhanTramGiam%</td>
                        <td>@String.Format("{0:dd/MM/yyyy}", item.NgayBatDau)</td>
                        <td>@String.Format("{0:dd/MM/yyyy}", item.NgayKetThuc)</td>
                        <td>
                            @* Logic kiểm tra thời hạn mã khuyến mãi *@
                            @if (item.NgayKetThuc >= DateTime.Now)
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3">Đang hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-3">Hết hạn</span>
                            }
                        </td>
                        <td class="text-center">
                            @* Nút xóa sử dụng MaKM làm ID *@
                            <a href="@Url.Action("XoaKhuyenMai", new { id = item.MaKM })"
                               class="btn btn-sm btn-admin-danger"
                               onclick="return confirm('Bạn có chắc muốn xóa mã này?')">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center py-5">
                        <i class="fas fa-ticket-alt fa-3x text-muted mb-3"></i>
                        <p class="text-muted">Chưa có mã khuyến mãi nào được tạo.</p>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>