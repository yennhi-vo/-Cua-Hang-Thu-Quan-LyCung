@model IEnumerable<PetShop.DichVu>
@{
    ViewBag.Title = "Quản lý Dịch Vụ";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="row mb-4">
    <div class="col-md-8">
        <form method="get" class="row g-3">
            <div class="col-md-6">
                <input type="text" name="search" class="form-control" placeholder="Tìm kiếm dịch vụ..." value="@ViewBag.Search">
            </div>
            <div class="col-md-4">
                <select name="category" class="form-select">
                    <option value="">Tất cả loại dịch vụ</option>
                    @foreach (var cat in ViewBag.Categories as List<PetShop.LoaiDichVu>)
                    {
                        <option value="@cat.MaLoai" @(ViewBag.Category == cat.MaLoai ? "selected" : "")>@cat.TenLoai</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-admin-primary w-100">
                    <i class="fas fa-search"></i> Tìm
                </button>
            </div>
        </form>
    </div>
    <div class="col-md-4 text-end">
        <a href="@Url.Action("ThemDichVu", "Admin")" class="btn btn-admin-primary">
            <i class="fas fa-plus"></i> Thêm Dịch Vụ
        </a>
    </div>
</div>

<div class="admin-table shadow-sm">
    <table class="table align-middle mb-0">
        <thead>
            <tr>
                <th style="width: 100px;" class="ps-3">Ảnh</th>
                <th>Tên Dịch Vụ</th>
                <th>Phân Loại</th>
                <th>Giá Gốc</th>
                <th class="text-success">Giá Khuyến Mãi</th>
                <th class="text-center" style="width: 150px;">Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-3">
                            <img src="@Url.Content("~/Content/Images/dichvu/" + item.Hinh)"
                                 class="rounded-circle shadow-sm border"
                                 style="width: 60px; height: 60px; object-fit: cover;"
                                 alt="@item.TenDichVu" />
                        </td>
                        <td><span class="fw-bold text-dark">@item.TenDichVu</span></td>
                        <td>
                            <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3">
                                @(item.LoaiDichVu != null ? item.LoaiDichVu.TenLoai : "Chưa phân loại")
                            </span>
                        </td>
                        <td class="text-muted small text-decoration-line-through">@((item.Gia ?? 0).ToString("N0"))₫</td>
                        <td class="fw-bold text-success">@((item.GiaKhuyenMai ?? 0).ToString("N0"))₫</td>
                        <td class="text-center">
                            <a href="@Url.Action("SuaDichVu", new { id = item.MaDichVu })" class="btn btn-sm btn-admin-warning">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a href="@Url.Action("XoaDichVu", new { id = item.MaDichVu })"
                               class="btn btn-sm btn-admin-danger"
                               onclick="return confirm('Bạn có chắc chắn muốn xóa dịch vụ này?')">
                                <i class="fas fa-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center py-5">
                        <i class="fas fa-concierge-bell fa-3x text-muted mb-3"></i>
                        <p class="text-muted">Không tìm thấy dịch vụ nào.</p>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>