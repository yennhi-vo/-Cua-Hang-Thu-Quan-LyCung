@model PetShop.Models.KetQuaTimKiemVM
@{
    ViewBag.Title = "Kết quả tìm kiếm";
}

<h4 class="mb-4">
    Kết quả tìm kiếm cho:
    <span class="text-bg-light">"@ViewBag.Keyword"</span>
</h4>


<div class="row">
    <!-- THÚ CƯNG -->
    @if (Model.ThuCungs != null && Model.ThuCungs.Any())
    {
        foreach (var tc in Model.ThuCungs)
        {
            <div class="col-md-3 mb-4">
                <div class="card shadow-sm h-100 card-hover">
                    <img src="~/Content/Images/Products/@tc.Hinh"
                         class="card-img-top"
                         style="height:220px; object-fit:cover;"
                         alt="@tc.TenThuCung" />

                    <div class="card-body text-center">
                        <span class="badge bg-primary mb-2">Thú cưng</span>
                        <h6>@tc.TenThuCung</h6>
                        <p class="text-danger fw-bold">@String.Format("{0:N0}", tc.Gia) VNĐ</p>

                        <a href="@Url.Action("Detail","Product", new { id = tc.MaThuCung })"
                           class="btn btn-outline-primary btn-sm">
                            Xem chi tiết
                        </a>
                    </div>
                </div>
            </div>
        }
    }

    <!-- PHỤ KIỆN -->
    @if (Model.PhuKiens != null && Model.PhuKiens.Any())
    {
        foreach (var pk in Model.PhuKiens)
        {
            <div class="col-md-3 mb-4">
                <div class="card shadow-sm h-100 card-hover">
                    <img src="~/Content/Images/Products/@pk.Hinh"
                         class="card-img-top"
                         style="height:220px; object-fit:cover;"
                         alt="@pk.TenPhuKien" />

                    <div class="card-body text-center">
                        <span class="badge bg-success mb-2">Phụ kiện</span>
                        <h6>@pk.TenPhuKien</h6>
                        <p class="text-danger fw-bold">@String.Format("{0:N0}", pk.Gia) VNĐ</p>

                        <a href="@Url.Action("DetailPK","Product", new { id = pk.MaPhuKien })"
                           class="btn btn-outline-success btn-sm">
                            Xem chi tiết
                        </a>
                    </div>
                </div>
            </div>
        }
    }

    <!-- DỊCH VỤ -->
    @if (Model.DichVus != null && Model.DichVus.Any())
    {
        foreach (var dv in Model.DichVus)
        {
            <div class="col-md-3 mb-4">
                <div class="card shadow-sm h-100 card-hover">
                    <img src="~/Content/Images/dichvu/@dv.Hinh"
                             class="card-img-top"
                             style="height:220px; object-fit:cover;"
                             alt="@dv.TenDichVu" />
    

                    <div class="card-body text-center">
                        <span class="badge bg-warning mb-2">Dịch vụ</span>
                        <h6>@dv.TenDichVu</h6>
                        <p class="text-danger fw-bold">@String.Format("{0:N0}", dv.Gia) VNĐ</p>

                        <a href="@Url.Action("DetailDV","Product", new { id = dv.MaDichVu })"
                           class="btn btn-outline-warning btn-sm">
                            Xem chi tiết
                        </a>
                    </div>
                </div>
            </div>
        }
    }

    <!-- THÔNG BÁO KHÔNG CÓ KẾT QUẢ -->
    @{
        var totalItems = (Model.ThuCungs?.Count ?? 0) + (Model.PhuKiens?.Count ?? 0) + (Model.DichVus?.Count ?? 0);
    }

    @if (totalItems == 0)
    {
        <div class="col-12 text-center py-5">
            <i class="bi bi-search display-1 text-muted"></i>
            <h5 class="mt-3 text-muted">Không tìm thấy kết quả nào</h5>
            <p class="text-muted">Hãy thử từ khóa tìm kiếm khác</p>
        </div>
    }
</div>