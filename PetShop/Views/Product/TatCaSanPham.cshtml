@model List<PetShop.ThuCung>

<div class="container mt-4">
    <div class="row">

        <aside class="col-md-3 col-lg-2 mb-4">

            <!-- Danh mục tat ca san pham  -->
            <h5 class="fw-bold">Tất cả sản phẩm</h5>
            @Html.Action("TatCaSanPham", "Product")


            <!-- Danh mục thú cưng -->
            <h5 class="fw-bold">Danh mục thú cưng</h5>
            @Html.Action("_ThuCung", "Product")

            <!-- Dịch vụ -->
            <h5 class="fw-bold mt-4">Dịch vụ</h5>
            @Html.Action("_Dichvu", "Product")

            <!-- Phụ kiện -->
            <h5 class="fw-bold mt-4">Phụ kiện</h5>
            @Html.Action("_PhuKien", "Product")


        </aside>

        <!-- ========== DANH SÁCH SẢN PHẨM ========== -->
        <main class="col-md-9 col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4 bg-light p-3 rounded shadow-sm">
                <h4 class="mb-0 fw-bold">Danh sách thú cưng</h4>

                @using (Html.BeginForm("Index", "Product", FormMethod.Get, new { @class = "d-flex align-items-center" }))
                {
                    <label class="me-2 fw-bold">Sắp xếp theo giá:</label>
                    <select name="sortOrder" class="form-select form-select-sm w-auto" onchange="this.form.submit()">
                        <option value="">-- Mặc định --</option>
                        <option value="price_asc" @(Request.QueryString["sortOrder"] == "price_asc" ? "selected" : "")>Giá tăng dần</option>
                        <option value="price_desc" @(Request.QueryString["sortOrder"] == "price_desc" ? "selected" : "")>Giá giảm dần</option>
                    </select>
                }
            </div>
            <h4 class="mb-3">Thú cưng nổi bật</h4>
            <div class="row">
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var item in Model)
                    {
                        <div class="col-md-3 mb-4">
                            <div class="card h-100 shadow-sm card-hover">
                                <img src="@Url.Content("~/Content/Images/thucung/" + item.Hinh)" class="card-img-top" alt="@item.TenThuCung" height="250">
                                <div class="card-body text-center">
                                    <h6 class="card-title">@item.TenThuCung</h6>
                                    <p class="text-danger fw-bold">@String.Format("{0:N0}", item.Gia) VNĐ</p>
                                    <a href="@Url.Action("Detail", "Product", new { id = item.MaThuCung })" class="btn btn-sm btn-outline-primary">
                                        Xem chi tiết
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-center text-muted">Không có sản phẩm nào được tìm thấy.</p>
                }
            </div>
        </main>
    </div>
</div>
