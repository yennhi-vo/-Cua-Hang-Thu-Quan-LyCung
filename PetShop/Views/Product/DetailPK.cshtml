@model PetShop.PhuKien

<div class="row">
    <div class="col-md-4">
        <div class="product-gallery">
            <img id="mainImage" src="@Url.Content("~/Content/Images/Products/" + Model.Hinh)"
                 alt="Ảnh Sản phẩm Chính" class="img-fluid border" style="max-width: 100%; height: 350px; object-fit: cover;">

            <div class="thumbnails mt-2 d-flex justify-content-start gap-2">
                <img class="img-thumbnail thumb-click"
                     src="@Url.Content("~/Content/Images/Product/" + Model.Hinh)"
                     data-full-src="@Url.Content("~/Content/Images/Products/" + Model.Hinh)"
                     style="width: 60px; height: 60px; cursor: pointer; object-fit: cover;">

                @if (Model.HinhAnhPhus != null)
                {
                    foreach (var imgPhu in Model.HinhAnhPhus)
                    {
                        <img class="img-thumbnail thumb-click"
                             src="@Url.Content("~/Content/Images/hinhanhphu/" + imgPhu.HinhAnh)"
                             data-full-src="@Url.Content("~/Content/Images/hinhanhphu/" + imgPhu.HinhAnh)"
                             style="width: 60px; height: 60px; cursor: pointer; object-fit: cover;">
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <h3>@Model.TenPhuKien</h3>
        <h4 class="text-danger">@String.Format("{0:N0}", Model.Gia) VNĐ</h4>
        <p class="mt-3">@Model.MoTa</p>

        <div class="mb-3">
            <a href="@Url.Action("AddToCart", "Cart", new { id = Model.MaPhuKien, loai = "PhuKien" })" class="btn btn-success">
                <i class="bi bi-cart-plus"></i> Thêm vào giỏ
            </a>
            <a href="@Url.Action("PhuKien", "Product")" class="btn btn-outline-secondary">Quay lại</a>
        </div>
    </div>
</div>




<div class="comment-form-container mt-4 p-3 border rounded shadow-sm">
    <h5 class="fw-bold"><i class="bi bi-pencil-square"></i> Viết bình luận của bạn</h5>

    <form action="@Url.Action("GuiBinhLuan", "Product")" method="post">
        <input type="hidden" name="id" value="@Model.MaPhuKien" />
        <input type="hidden" name="loai" value="PhuKien" />

        <div class="mb-3">
            <textarea name="noiDung" class="form-control" rows="3" placeholder="Nhập nội dung đánh giá..." required></textarea>
        </div>

        @if (Session["User"] != null)
        {
            <button type="submit" class="btn btn-success">Gửi bình luận</button>
        }
        else
        {
            <div class="alert alert-info py-2">
                Vui lòng <a href="@Url.Action("Login", "User")">Đăng nhập</a> để bình luận.
            </div>
        }
    </form>
</div>



<hr />

<div class="mt-5 mb-5">
    <h3 style="color:forestgreen" class="mb-4"><i class="bi bi-chat-dots"></i> Khách hàng đánh giá</h3>
    <div class="row">
        <div class="col-md-12">
            @if (Model.BinhLuans != null && Model.BinhLuans.Any())
            {
                <div class="list-group">
                    @foreach (var bl in Model.BinhLuans.OrderByDescending(x => x.NgayDang))
                    {
                        <div class="list-group-item mb-3 shadow-sm rounded border">
                            <div class="d-flex w-100 justify-content-between">
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold"
                                         style="width: 40px; height: 40px;">
                                        @(bl.KhachHang?.HoTen?.Substring(0, 1).ToUpper() ?? "K")
                                    </div>
                                    <div class="ms-3">
                                        <h6 class="mb-0 fw-bold">@(bl.KhachHang?.HoTen ?? "Khách hàng ẩn danh")</h6>
                                        <small class="text-muted">@bl.NgayDang</small>
                                    </div>
                                </div>
                            </div>
                            <p class="mt-3 mb-1 text-secondary">"@bl.NoiDung"</p>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-light border text-center text-muted">
                    Chưa có đánh giá nào cho phụ kiện này.
                </div>
            }
        </div>
    </div>
</div>
<!-- Sản phẩm liên quan -->
<div class="mt-5">
    <h3 style="color:forestgreen">Sản phẩm liên quan</h3>
    <hr />
    <div class="row">
        @foreach (var item in ViewBag.SPLienQuanPK)
        {
            <div class="col-md-3 mb-4">
                <div class="card h-100 shadow-sm card-hover">
                    <img src="@Url.Content("~/Content/Images/Products/" + item.Hinh)" class="card-img-top" alt="@item.TenPhuKien" height="250">
                    <div class="card-body text-center">
                        <h6 class="card-title">@item.TenPhuKien</h6>
                        <p class="text-danger fw-bold">@String.Format("{0:N0}", item.Gia) VNĐ</p>
                        <a href="@Url.Action("Detail", "Product", new { id = item.MaPhuKien })" class="btn btn-sm btn-outline-primary">
                            Xem chi tiết
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
<script>
    $(document).ready(function () {
        $(".thumb-click").on("click", function () {
            var newImageSrc = $(this).data("full-src");
            $("#mainImage").attr("src", newImageSrc);
            $(".thumb-click").removeClass("border-primary");
            $(this).addClass("border-primary");
        });
    });
</script>