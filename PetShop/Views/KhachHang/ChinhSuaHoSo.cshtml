@model PetShop.KhachHang
@{
    ViewBag.Title = "Chỉnh sửa hồ sơ";
    Layout = "~/Views/Shared/_Layout.cshtml"; 
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Chỉnh sửa thông tin cá nhân</h4>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm())
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(model => model.MaKH)

                        <div class="form-group mb-3">
                            <label class="font-weight-bold">Họ và tên</label>
                            @Html.EditorFor(model => model.HoTen, new { htmlAttributes = new { @class = "form-control" } })
                        </div>

                        <div class="form-group mb-3">
                            <label class="font-weight-bold">Email</label>
                            @Html.EditorFor(model => model.Email, new { htmlAttributes = new { @class = "form-control" } })
                        </div>

                        <div class="form-group mb-3">
                            <label class="font-weight-bold">Số điện thoại</label>
                            @Html.EditorFor(model => model.SDT, new { htmlAttributes = new { @class = "form-control" } })
                        </div>

                        <div class="form-group mb-3">
                            <label class="font-weight-bold">Địa chỉ</label>
                            @Html.TextAreaFor(model => model.DiaChi, new { @class = "form-control", rows = "2" })
                        </div>

                        <div class="d-flex justify-content-between">
                            <button type="submit" class="btn btn-success px-4">Lưu thay đổi</button>
                            <a href="@Url.Action("Profile", new { id = Model.MaKH })" class="btn btn-secondary">Hủy bỏ</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>