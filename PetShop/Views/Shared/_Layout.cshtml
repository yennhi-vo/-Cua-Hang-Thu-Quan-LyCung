
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - Pet Shop</title>

    <!-- Bootstrap CSS & Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/js/bootstrap.bundle.min.js"></script>
    <link href="~/Content/Site.css" rel="stylesheet" />

    <style>
        /* 1. Đổi màu cho các link trên menu khi hover */
        .navbar-light .navbar-nav .nav-link:hover,
        .navbar-light .navbar-nav .nav-link.active {
            color: #198754 !important; /* Màu xanh lá Success */
        }

        /* 2. Đổi màu cho các mục trong Dropdown khi hover */
        .dropdown-item:hover {
            background-color: #f8f9fa; /* Nền xám cực nhẹ */
            color: #198754 !important; /* Chữ xanh lá */
        }

        /* 3. Đổi màu viền và chữ cho nút tìm kiếm */
        .btn-outline-success {
            color: #198754;
            border-color: #198754;
        }

            .btn-outline-success:hover {
                background-color: #198754;
                border-color: #198754;
                color: #fff;
            }

        /* 4. Đổi màu nút Đăng nhập (nếu đang dùng btn-primary) */
        .btn-primary {
            background-color: #198754 !important;
            border-color: #198754 !important;
        }

            .btn-primary:hover {
                background-color: #146c43 !important; /* Xanh lá đậm hơn một chút khi hover */
                border-color: #146c43 !important;
            }

        /* 5. Hiệu ứng gạch chân dưới mỗi mục menu khi hover (tùy chọn cho đẹp) */
        .nav-link {
            position: relative;
            transition: color 0.3s ease;
        }

            .nav-link::after {
                content: '';
                position: absolute;
                width: 0;
                height: 2px;
                bottom: 0;
                left: 0;
                background-color: #198754;
                transition: width 0.3s ease;
            }

            .nav-link:hover::after {
                width: 100%;
            }
    </style>
</head>

<body>
    <!-- HEADER / NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
        <div class="container">

            <!-- Logo -->
            <a class="navbar-brand d-flex align-items-center fw-bold fs-3" href="@Url.Action("Index","Home")">
                <img src="@Url.Content("~/Content/Images/logo.jpg")"
                     alt="Pet Shop Logo"
                     class="rounded-circle me-2"
                     style="width:100px; height:100px; object-fit:cover;" />
                Pet Shop
            </a>

            <!-- Toggle Button (Mobile) -->
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="@Url.Action("Index","Home")">Trang chủ</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("About","Home")">Giới thiệu</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "News")">Tin tức</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("DichVu","Product")">Dịch vụ</a>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Thú cưng</a>
                        <ul class="dropdown-menu">@Html.Action("_ThuCung", "Product")</ul>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">Phụ kiện</a>
                        <ul class="dropdown-menu">@Html.Action("_PhuKien", "Product")</ul>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="@Url.Action("Index", "Booking")">Liên hệ</a>
                    </li>
                </ul>

                <div class="d-flex align-items-center">
                    @using (Html.BeginForm("TimKiem", "Product", FormMethod.Get, new { @class = "d-flex me-2" }))
                    {
                        <div class="input-group input-group-sm" style="max-width: 200px;">
                            <input class="form-control" name="keyword" type="search" placeholder="Tìm kiếm..." />
                            <button class="btn btn-outline-success" type="submit"><i class="bi bi-search"></i></button>
                        </div>
                    }

                    @if (Session["User"] != null)
                    {
                        <a href="@Url.Action("Index","Cart")" class="btn btn-sm btn-outline-dark position-relative me-3">
                            <i class="bi bi-cart3 fs-5"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                @(Session["Cart"] != null ? ((PetShop.Models.Cart)Session["Cart"]).SoLuongMH() : 0)
                            </span>
                        </a>
                    }

                    <ul class="navbar-nav">
                        @if (Session["User"] == null && Session["Admin"] == null)
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm px-3" href="@Url.Action("Login", "User")">Đăng nhập</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-bold text-dark" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle me-1"></i>
                                    Tài khoản
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                                    @if (Session["User"] != null)
                                    {
                                        <li><a class="dropdown-item" href="@Url.Action("Profile","KhachHang")"><i class="bi bi-person me-2"></i>Hồ sơ cá nhân</a></li>
                                       
                                    }
                                    @if (Session["Admin"] != null)
                                    {
                                        <li><a class="dropdown-item text-danger fw-bold" href="@Url.Action("Index", "Admin")"><i class="bi bi-shield-lock me-2"></i>Quản trị hệ thống</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-muted" href="@Url.Action("Logout","User")"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <div class="container mt-4">
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        @RenderBody()
    </div>

    <!-- FOOTER -->
    <footer class="mt-5 bg-light border-top">
        <section class="py-5 text-center">
            <div class="container">
                <p class="text-uppercase text-muted fs-5">Liên hệ với chúng tôi</p>
                <h2 class="fw-bold mb-3">Liên Hệ PetCare Ngay Hôm Nay</h2>
                <p>
                    Hãy kết nối với chúng tôi để nhận tư vấn, hỗ trợ và giải đáp mọi thắc mắc về chăm sóc thú cưng.
                    Chúng tôi luôn sẵn sàng đồng hành cùng bạn trong hành trình yêu thương thú cưng.
                </p>

                <div class="row mt-4">
                    <div class="col-md-4">
                        <i class="bi bi-envelope fs-2 text-primary"></i>
                        <h5 class="fw-bold mt-2">Email</h5>
                        <p>
                            Gửi thư cho chúng tôi tại
                            <a href="mailto:info@petshoppro.com">info@petcarepro.com</a>.
                        </p>
                    </div>

                    <div class="col-md-4">
                        <i class="bi bi-telephone fs-2 text-primary"></i>
                        <h5 class="fw-bold mt-2">Điện thoại</h5>
                        <p>
                            Gọi <a href="tel:+19000091">0969887224</a> để được hỗ trợ nhanh chóng.
                        </p>
                    </div>

                    <div class="col-md-4">
                        <i class="bi bi-geo-alt fs-2 text-primary"></i>
                        <h5 class="fw-bold mt-2">Địa chỉ</h5>
                        <p>
                            140 Lê Trọng Tấn, Phường Tây Thạnh, Quận Tân Phú, TP.HCM<br />
                            <a href="https://www.google.com/maps/place/Trường+Đại+học+Công+Thương+TP.HCM/">Xem bản đồ</a>
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <div class="text-center py-3 border-top bg-white">
            © @DateTime.Now.Year Pet Shop — All rights reserved.
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("scripts", required: false)
</body>
</html>
